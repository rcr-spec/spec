{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rcr-spec.org/schema/closure-bundle-v1.5.json",
  "title": "RANKIGI Closure Bundle v1.5",
  "description": "Container that ships a chain of canonical agent events plus RCR/1 receipts and external anchors. Accepted by the reference verifier verify.py.",
  "type": "object",
  "required": ["rankigi_proof_bundle_schema", "events"],
  "additionalProperties": true,
  "properties": {
    "rankigi_proof_bundle_schema": {
      "type": "string",
      "const": "1.5"
    },
    "exported_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "receipt6": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{6}$",
      "description": "Six lowercase hex chars; the public-access prefix for the bundle."
    },
    "envelope": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "passport_key_fingerprint": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-fA-F]+$"
        },
        "passport_public_key_pem": {
          "type": ["string", "null"],
          "description": "PEM-wrapped Ed25519 SPKI. Verifier loads with load_pem_public_key."
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/event" }
    },
    "rcr_receipts": {
      "type": "array",
      "items": { "$ref": "https://rcr-spec.org/schema/rcr-receipt-v1.json" }
    },
    "rekor_anchor": {
      "type": "object",
      "required": ["log_index"],
      "additionalProperties": true,
      "properties": {
        "log_index": { "type": "integer", "minimum": 0 },
        "anchor_payload_hash": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$",
          "description": "SHA-256 hex of the bytes the cron anchored at this Rekor entry."
        }
      }
    },
    "rfc3161_timestamp": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tsa_url": { "type": "string", "format": "uri" },
        "tsa_timestamp": { "type": "string", "format": "date-time" },
        "tsr_token_base64": { "type": "string", "contentEncoding": "base64" },
        "tsa_cert_chain_pem": { "type": "string" },
        "message_imprint_hash": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        }
      }
    },
    "tsa_tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "event_id": { "type": ["string", "null"] },
          "tsa_url": { "type": "string" },
          "verified_at": { "type": "string" },
          "token_present": { "type": "boolean" },
          "tsr_token_base64": { "type": "string", "contentEncoding": "base64" },
          "tsa_cert_chain_pem": { "type": "string" },
          "message_imprint_hash": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{64}$"
          }
        }
      }
    },
    "verify_with": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "script": { "type": "string", "format": "uri" },
        "usage": { "type": "string" },
        "pubkey_endpoint": { "type": "string", "format": "uri" }
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "required": ["action", "agent_id", "occurred_at", "hash", "prev_hash"],
      "additionalProperties": true,
      "properties": {
        "action": { "type": "string", "minLength": 1 },
        "agent_id": { "type": "string", "format": "uuid" },
        "org_id": { "type": "string", "format": "uuid" },
        "chain_id": { "type": ["string", "null"], "format": "uuid" },
        "canon_id": { "type": ["string", "null"] },
        "canon_version": { "type": ["string", "null"] },
        "nonce": { "type": ["string", "null"] },
        "occurred_at": { "type": "string", "format": "date-time" },
        "payload": { "type": ["object", "null"] },
        "payload_canonical": {
          "type": ["string", "null"],
          "description": "Pre-canonicalized payload bytes. When present, the verifier splices these verbatim into the hash preimage instead of re-canonicalizing payload."
        },
        "payload_canonical_encrypted": {
          "type": ["string", "null"],
          "contentEncoding": "base64",
          "description": "AES-256-GCM envelope over the canonical payload. Verifier reports PARTIAL when this is set without a master key."
        },
        "tool": { "type": ["string", "null"] },
        "severity": { "type": ["string", "null"] },
        "passport_fingerprint": { "type": ["string", "null"] },
        "signature_hash": { "type": ["string", "null"] },
        "signature": {
          "type": ["string", "null"],
          "contentEncoding": "base64",
          "description": "Ed25519 signature over the canonical event bytes."
        },
        "hash": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "prev_hash": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{0,64}$"
        },
        "chain_index": { "type": ["integer", "null"], "minimum": 0 },
        "hash_version": {
          "type": ["integer", "null"],
          "enum": [1, 2, 3, 4, null]
        }
      }
    }
  }
}
